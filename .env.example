# ─── LLM Configuration ───
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Control Loop ───
CONTROL_CYCLE_INTERVAL=15
SIMULATION_SCENARIOS=100
DEBUG=false

# ─── Notifications ───
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=

# ─── Infrastructure ───
PROMETHEUS_URL=http://prometheus:9090
REDIS_URL=redis://redis:6379/0
KUBERNETES_IN_CLUSTER=false
